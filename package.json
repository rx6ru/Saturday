{
  "name": "satur-day",
  "version": "1.1.0",
  "description": "Saturday turns any codebase into a voice-queryable knowledge base",
  "keywords": [
    "voice",
    "codebase",
    "rag",
    "vapi",
    "qdrant",
    "assistant"
  ],
  "author": "",
  "license": "MIT",
  "bin": {
    "satur-day": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc && node scripts/copy-web.mjs",
    "copy:web": "node scripts/copy-web.mjs",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@ngrok/ngrok": "^1.7.0",
    "@qdrant/js-client-rest": "^1.7.0",
    "@vapi-ai/server-sdk": "^0.1.0",
    "@vapi-ai/web": "^2.5.2",
    "commander": "^12.0.0",
    "express": "^4.18.2",
    "fast-glob": "^3.3.2",
    "openai": "^4.50.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/supertest": "^6.0.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.7",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
